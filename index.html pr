/* ============================
   IDENTIFIANT UNIQUE APPAREIL
============================= */
function getDeviceId(){
  let did = localStorage.getItem('pcp_device_id');
  if(!did){
    did = 'DEV-' + Date.now() + '-' + Math.random().toString(36).substring(2,10).toUpperCase();
    localStorage.setItem('pcp_device_id', did);
  }
  return did;
}
const DEVICE_ID = getDeviceId();

async function verifyCode(){
  const code = document.getElementById('code-input').value.trim().toUpperCase();
  if(!code){ showModalMsg('Veuillez saisir un code.','error'); return; }

  showModalMsg('⏳ Vérification en cours...','');

  if(fbReady && db){
    try{
      const snap = await db.ref('codes/'+code.replace(/-/g,'_')).once('value');
      const data = snap.val();

      if(!data){
        showModalMsg('❌ Code invalide. Contactez Prof. TONI sur WhatsApp.','error');
        return;
      }

      // Code déjà utilisé → vérifier si c'est le même appareil
      if(data.used){
        if(data.deviceId && data.deviceId === DEVICE_ID){
          // Même appareil → on réaccorde l'accès silencieusement
          grantAccess(code);
        } else {
          showModalMsg('❌ Ce code a déjà été activé sur un autre appareil. Contactez Prof. TONI.','error');
        }
        return;
      }

      // Code valide et pas encore utilisé → on l'active et on lie à cet appareil
      await db.ref('codes/'+code.replace(/-/g,'_')).update({
        used: true,
        usedAt: new Date().toISOString(),
        deviceId: DEVICE_ID
      });
      grantAccess(code);
      return;

    } catch(e){ /* fallback local */ }
  }

  // Vérification locale (si Firebase indisponible)
  const codeObj = localCodes.find(c=>c.code===code);
  if(!codeObj){
    showModalMsg('❌ Code invalide. Contactez Prof. TONI sur WhatsApp.','error');
    return;
  }
  if(codeObj.used && codeObj.deviceId && codeObj.deviceId !== DEVICE_ID){
    showModalMsg('❌ Ce code est déjà lié à un autre appareil.','error');
    return;
  }
  codeObj.used = true;
  codeObj.deviceId = DEVICE_ID;
  saveCodes();
  grantAccess(code);
}

function grantAccess(code){
  hasAccess = true;
  localStorage.setItem('pcp_access','true');
  localStorage.setItem('pcp_code', code);
  localStorage.setItem('pcp_device_id', DEVICE_ID);
  showModalMsg('✅ Accès débloqué ! Bienvenue, tous les sujets sont disponibles.','success');
  // Cacher le bandeau après succès
  document.getElementById('bandeau-code').style.display = 'none';
  setTimeout(()=>{
    closeCodeModal();
    renderSubjects(currentFilter);
  }, 2000);
}

// Vérification depuis le bandeau inline
async function verifyInlineCode(){
  const code = document.getElementById('inline-code-input').value.trim().toUpperCase();
  const msgEl = document.getElementById('inline-code-msg');
  if(!code){ showInlineMsg('Veuillez saisir votre code.','error'); return; }
  showInlineMsg('⏳ Vérification...','info');

  // Réutiliser la même logique Firebase
  if(fbReady && db){
    try{
      const snap = await db.ref('codes/'+code.replace(/-/g,'_')).once('value');
      const data = snap.val();
      if(!data){ showInlineMsg('❌ Code invalide. Contactez Prof. TONI.','error'); return; }
      if(data.used && data.deviceId && data.deviceId !== DEVICE_ID){
        showInlineMsg('❌ Code déjà utilisé sur un autre appareil.','error'); return;
      }
      if(!data.used){
        await db.ref('codes/'+code.replace(/-/g,'_')).update({used:true,usedAt:new Date().toISOString(),deviceId:DEVICE_ID});
      }
      showInlineMsg('✅ Accès débloqué ! Chargement...','success');
      setTimeout(()=>{ hasAccess=true; localStorage.setItem('pcp_access','true'); localStorage.setItem('pcp_code',code); document.getElementById('bandeau-code').style.display='none'; renderSubjects(currentFilter); }, 1500);
      return;
    } catch(e){}
  }
  // Fallback local
  const codeObj = localCodes.find(c=>c.code===code);
  if(!codeObj){ showInlineMsg('❌ Code invalide.','error'); return; }
  if(codeObj.used && codeObj.deviceId !== DEVICE_ID){ showInlineMsg('❌ Code déjà utilisé sur un autre appareil.','error'); return; }
  codeObj.used=true; codeObj.deviceId=DEVICE_ID; saveCodes();
  showInlineMsg('✅ Accès débloqué !','success');
  setTimeout(()=>{ hasAccess=true; localStorage.setItem('pcp_access','true'); document.getElementById('bandeau-code').style.display='none'; renderSubjects(currentFilter); }, 1500);
}

