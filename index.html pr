============================= */
function toggleMenu(){
  const links = document.querySelector('.nav-links');
  links.style.display = links.style.display==='flex' ? 'none' : 'flex';
  links.style.position = 'absolute';
  links.style.top = '70px';
  links.style.left = '0';
  links.style.right = '0';
  links.style.background = 'var(--bg2)';
