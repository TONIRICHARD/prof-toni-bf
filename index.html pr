      <button class="btn-quiz primary" style="max-width:200px;margin:0 auto" onclick="startQuiz()">Démarrer</button>
    </div>`;
}

function startQuiz(){
  quizQuestions = [...QUIZ_DATA[quizMat]].sort(()=>Math.random()-.5).slice(0,5);
  quizIndex = 0; quizScore = 0; quizActive = true;
  showQuestion();
}

function showQuestion(){
  if(quizIndex >= quizQuestions.length){ endQuiz(); return; }
  const q = quizQuestions[quizIndex];
  quizTimeLeft = 30;
  clearInterval(quizTimer);
  quizTimer = setInterval(()=>{
    quizTimeLeft--;
    const tEl = document.getElementById('q-timer');
    if(tEl) tEl.textContent = quizTimeLeft+'s';
    if(quizTimeLeft<=0){ clearInterval(quizTimer); nextQuestion(); }
  }, 1000);
  document.getElementById('quiz-container').innerHTML = `
    <div class="quiz-header">
      <div class="quiz-timer"><i class="fas fa-clock"></i> <span id="q-timer">30s</span></div>
      <div class="quiz-score-display">Q${quizIndex+1}/5 · Score: ${quizScore}</div>
    </div>
    <div class="quiz-progress"><div class="quiz-progress-fill" style="width:${(quizIndex/5)*100}%"></div></div>
    <div class="quiz-question">${q.q}</div>
    <div class="quiz-options">
      ${q.opts.map((o,i)=>`<button class="quiz-option" onclick="selectOption(this,${i},${q.ans})">${o}</button>`).join('')}
    </div>`;
}

function selectOption(el, chosen, correct){
  clearInterval(quizTimer);
  document.querySelectorAll('.quiz-option').forEach(b=>b.onclick=null);
  if(chosen===correct){ el.classList.add('correct'); quizScore++; }
  else {
    el.classList.add('wrong');
    document.querySelectorAll('.quiz-option')[correct].classList.add('correct');
  }
  setTimeout(nextQuestion, 1200);
}

function nextQuestion(){ quizIndex++; showQuestion(); }

function endQuiz(){
  quizActive = false;
  const pct = Math.round((quizScore/quizQuestions.length)*100);
  const emoji = pct>=80?'🏆':pct>=60?'👍':pct>=40?'📚':'💪';
  document.getElementById('quiz-container').innerHTML = `
    <div class="quiz-result">
      <div class="result-score">${pct}%</div>
      <div class="result-label">${quizScore}/${quizQuestions.length} bonnes réponses ${emoji}</div>
      <p style="color:var(--text2);font-size:.88rem;margin-bottom:1.5rem">
        ${pct>=80 ? 'Excellent ! Vous maîtrisez bien cette matière.' : pct>=60 ? 'Bon résultat ! Continuez à vous exercer.' : 'Des révisions s\'imposent. Consultez nos sujets corrigés !'}
      </p>
      <div style="display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap">
        <button class="btn-quiz primary" onclick="startQuiz()" style="max-width:160px">Rejouer</button>
        <button class="btn-quiz secondary" onclick="saveScore(${pct})" style="max-width:160px">Sauvegarder</button>
      </div>
    </div>`;
  saveScore(pct);
}

function saveScore(pct){
  const scores = JSON.parse(localStorage.getItem('pcp_scores') || '[]');
  scores.push({mat:quizMat,score:pct,date:new Date().toLocaleDateString()});
  localStorage.setItem('pcp_scores', JSON.stringify(scores));
  renderLeaderboard();
}

