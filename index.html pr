}

/* ============================
   SCROLL REVEAL
============================= */
function initReveal(){
  const els = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  },{threshold:.15});
  els.forEach(el=>obs.observe(el));
}

