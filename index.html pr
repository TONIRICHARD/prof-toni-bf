function ajouterSujet(){
  const titre    = document.getElementById('sj-titre').value.trim();
  const matiere  = document.getElementById('sj-matiere').value;
  const annee    = parseInt(document.getElementById('sj-annee').value) || 2026;
  const pages    = parseInt(document.getElementById('sj-pages').value) || 0;
  const free     = document.getElementById('sj-acces').value === 'true';
  const corrige  = document.getElementById('sj-corrige').checked;
  const pdf      = document.getElementById('sj-pdf').value.trim();
  const corrigeUrl = document.getElementById('sj-corrige-url').value.trim();
  const msgEl    = document.getElementById('sj-msg');

  if(!titre){ showSjMsg('❌ Le titre est obligatoire.','error'); return; }
  if(!pdf)  { showSjMsg('❌ Le lien PDF est obligatoire.','error'); return; }

  const newId = Date.now();
  const sujet = {id:newId, titre, matiere, annee, pages, free, corrige, pdf, corrigeUrl, date: new Date().toLocaleDateString('fr-FR')};

  // Enregistrement local
  dynamicSujets.unshift(sujet);
  saveSujets();

  // Enregistrement Firebase
  if(fbReady && db){
    db.ref('sujets/'+newId).set(sujet).catch(()=>{});
  }

  // Réinitialiser le formulaire
  document.getElementById('sj-titre').value='';
  document.getElementById('sj-pdf').value='';
  document.getElementById('sj-corrige-url').value='';
  document.getElementById('sj-pages').value='';
  document.getElementById('sj-corrige').checked=false;

  showSjMsg('✅ Sujet "'+titre+'" publié avec succès sur la plateforme !','success');
  refreshSujetsTable();
  renderSubjects(currentFilter); // Mettre à jour la grille publique
  updateAdminStats();
}

function showSjMsg(msg, type){
  const el = document.getElementById('sj-msg');
  el.textContent = msg;
  el.className = 'modal-msg '+type+' show';
  setTimeout(()=>el.classList.remove('show'), 4000);
}

