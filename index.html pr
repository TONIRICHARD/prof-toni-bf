  lb.innerHTML = LEADERBOARD_DEMO.map((e,i)=>`
    <div class="lb-item">
      <div class="lb-rank ${medals[i]||''}">${i<3?medalsEmoji[i]:i+1}</div>
      <div class="lb-avatar">${e.name.split(' ').map(w=>w[0]).join('')}</div>
      <div class="lb-name">${e.name}</div>
      <span class="lb-badge">${e.mat}</span>
      <div class="lb-score">${e.score}%</div>
    </div>`).join('');
}

/* ============================
   ADMIN
============================= */
const ADMIN_PASSWORD = 'toni2026';

function openAdminLogin(){
  document.getElementById('admin-overlay').classList.add('show');
  if(adminLoggedIn){ showAdminDashboard(); }
}

function checkAdminLogin(){
  const pwd = document.getElementById('admin-pwd').value;
  const msg = document.getElementById('admin-login-msg');
  if(pwd === ADMIN_PASSWORD){
    adminLoggedIn = true;
    showAdminDashboard();
  } else {
    msg.textContent = '❌ Mot de passe incorrect.';
    msg.className = 'modal-msg error show';
  }
}

function showAdminDashboard(){
  document.getElementById('admin-login-section').style.display='none';
  document.getElementById('admin-dashboard').style.display='block';
  refreshCodesTable();
  refreshSujetsTable();
  updateAdminStats();
}

function closeAdmin(){
  document.getElementById('admin-overlay').classList.remove('show');
  document.getElementById('admin-login-section').style.display='block';
  document.getElementById('admin-dashboard').style.display='none';
  document.getElementById('admin-pwd').value='';
  adminLoggedIn = false;
}

function generateCode(){
  const mat = document.getElementById('gen-matiere').value;
  const nom = document.getElementById('gen-nom').value.trim() || 'Anonyme';
  const rand = Math.random().toString(36).substring(2,8).toUpperCase();
  const code = `${mat}-2026-${rand}`;
  const entry = {code,matiere:mat,eleve:nom,date:new Date().toLocaleDateString('fr-FR'),used:false};
  localCodes.unshift(entry);
  saveCodes();

  // Enregistrer sur Firebase si disponible
  if(fbReady && db){
    db.ref('codes/'+code.replace(/-/g,'_')).set({...entry,usedAt:null}).catch(()=>{});
  }

  const msg = document.getElementById('gen-msg');
  msg.textContent = `✅ Code généré : ${code}`;
  msg.className = 'modal-msg success show';
  refreshCodesTable();
  setTimeout(()=>msg.classList.remove('show'), 4000);
}

function deleteCode(code){
  localCodes = localCodes.filter(c=>c.code!==code);
  saveCodes();
  if(fbReady && db) db.ref('codes/'+code.replace(/-/g,'_')).remove().catch(()=>{});
  refreshCodesTable();
}

function refreshCodesTable(){
  const tbody = document.getElementById('codes-tbody');
  updateAdminStats();
  tbody.innerHTML = localCodes.map(c=>`
    <tr>
      <td><span class="code-val">${c.code}</span></td>
      <td>${c.matiere}</td>
      <td>${c.eleve}</td>
      <td>${c.date}</td>
      <td><span class="code-status ${c.used?'used':'active'}">${c.used?'✅ Utilisé':'🟢 Actif'}</span></td>
      <td style="font-size:.7rem;color:var(--text3)">${c.deviceId ? '📱 Lié':'–'}</td>
      <td><button class="btn-small del" onclick="deleteCode('${c.code}')"><i class="fas fa-trash"></i></button></td>
    </tr>`).join('');
}

/* ============================
   THEME TOGGLE
============================= */
function toggleTheme(){
  const html = document.documentElement;
  const isDark = html.getAttribute('data-theme')==='dark';
  html.setAttribute('data-theme', isDark?'light':'dark');
  document.getElementById('theme-icon').className = isDark?'fas fa-sun':'fas fa-moon';
  localStorage.setItem('pcp_theme', isDark?'light':'dark');
}

