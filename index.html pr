<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>PrepaConcoursProf | Prof. TONI – Maths/PC · Maths/SVT niveau Bac</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>

<!-- Firebase SDK -->
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-database-compat.js"></script>

<style>
/* ============================================================
   VARIABLES & RESET
============================================================ */
:root {
  --bg: #0a0c10;
  --bg2: #11141c;
  --bg3: #171b25;
  --card: #1a1f2e;
  --border: rgba(255,255,255,0.07);
  --gold: #f5c842;
  --gold2: #e8a820;
  --teal: #00d4aa;
  --teal2: #00b894;
  --red: #ff4757;
  --blue: #3d85f7;
  --text: #e8eaf0;
  --text2: #8b93a8;
  --text3: #5a6172;
  --radius: 16px;
  --shadow: 0 20px 60px rgba(0,0,0,0.5);
}
[data-theme="light"] {
  --bg: #f0f2f8;
  --bg2: #ffffff;
  --bg3: #e8ecf5;
  --card: #ffffff;
  --border: rgba(0,0,0,0.08);
  --text: #1a1f2e;
  --text2: #4a5568;
  --text3: #9aa0b0;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;line-height:1.6}

/* ============================================================
   NOISE OVERLAY
============================================================ */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  opacity:.4;
}

/* ============================================================
   SCROLLBAR
============================================================ */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--teal);border-radius:3px}

/* ============================================================
   NAV
============================================================ */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  display:flex;align-items:center;justify-content:space-between;
  padding:1rem 2rem;
  background:rgba(10,12,16,0.85);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  transition:all .3s;
}
.nav-logo{
  font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;
  background:linear-gradient(135deg,var(--gold),var(--teal));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  text-decoration:none;
}
.nav-links{display:flex;align-items:center;gap:1.5rem}
.nav-links a{color:var(--text2);text-decoration:none;font-size:.9rem;font-weight:500;transition:color .2s}
.nav-links a:hover{color:var(--teal)}
.nav-actions{display:flex;align-items:center;gap:.75rem}
.btn-theme{background:var(--card);border:1px solid var(--border);color:var(--text2);padding:.45rem .7rem;border-radius:8px;cursor:pointer;font-size:.85rem;transition:all .2s}
.btn-theme:hover{color:var(--gold);border-color:var(--gold)}
.btn-admin{background:transparent;border:1px solid var(--teal);color:var(--teal);padding:.45rem 1rem;border-radius:8px;cursor:pointer;font-size:.85rem;font-weight:500;transition:all .2s}
.btn-admin:hover{background:var(--teal);color:#000}
.btn-unlock{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#000;border:none;padding:.5rem 1.2rem;border-radius:8px;cursor:pointer;font-size:.85rem;font-weight:700;transition:transform .2s,box-shadow .2s}
.btn-unlock:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(245,200,66,.3)}
.hamburger{display:none;background:none;border:none;color:var(--text);font-size:1.3rem;cursor:pointer}

/* ============================================================
   HERO
============================================================ */
.hero{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  text-align:center;padding:6rem 1.5rem 3rem;position:relative;overflow:hidden;
}
.hero-glow{
  position:absolute;top:-200px;left:50%;transform:translateX(-50%);
  width:800px;height:800px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,212,170,.12) 0%,rgba(245,200,66,.06) 40%,transparent 70%);
  pointer-events:none;animation:pulse 6s ease-in-out infinite;
}
@keyframes pulse{0%,100%{transform:translateX(-50%) scale(1)}50%{transform:translateX(-50%) scale(1.08)}}
.hero-badge{
  display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(0,212,170,.1);border:1px solid rgba(0,212,170,.3);
  color:var(--teal);padding:.4rem 1rem;border-radius:50px;font-size:.8rem;font-weight:600;
  letter-spacing:.05em;text-transform:uppercase;margin-bottom:2rem;
  animation:fadeDown .6s ease both;
}
.hero h1{
  font-family:'Syne',sans-serif;font-size:clamp(2.4rem,7vw,5rem);font-weight:800;line-height:1.08;
  margin-bottom:1.5rem;animation:fadeUp .7s .1s ease both;
}
.hero h1 .accent-gold{color:var(--gold)}
.hero h1 .accent-teal{color:var(--teal)}
.hero-sub{
  font-size:1.1rem;color:var(--text2);max-width:560px;margin:0 auto 2.5rem;
  animation:fadeUp .7s .2s ease both;
}
.hero-ctas{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;animation:fadeUp .7s .3s ease both}
.cta-primary{
  background:linear-gradient(135deg,var(--teal),var(--teal2));
  color:#000;border:none;padding:.85rem 2rem;border-radius:12px;font-size:1rem;font-weight:700;
  cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:.5rem;text-decoration:none;
}
.cta-primary:hover{transform:translateY(-3px);box-shadow:0 12px 30px rgba(0,212,170,.35)}
.cta-secondary{
  background:transparent;border:1px solid var(--border);color:var(--text);
  padding:.85rem 2rem;border-radius:12px;font-size:1rem;font-weight:500;
  cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:.5rem;text-decoration:none;
}
.cta-secondary:hover{border-color:var(--gold);color:var(--gold)}
.hero-stats{
  display:flex;justify-content:center;gap:3rem;flex-wrap:wrap;
  margin-top:4rem;padding-top:3rem;border-top:1px solid var(--border);
  animation:fadeUp .7s .4s ease both;
}
.stat-item{text-align:center}
.stat-num{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--gold)}
.stat-label{font-size:.8rem;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-top:.25rem}

/* ============================================================
   SECTION GENERIC
============================================================ */
section{padding:5rem 1.5rem;position:relative}
.container{max-width:1100px;margin:0 auto}
.section-tag{
  display:inline-block;font-size:.75rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  color:var(--teal);background:rgba(0,212,170,.08);border:1px solid rgba(0,212,170,.2);
  padding:.3rem .9rem;border-radius:50px;margin-bottom:1rem;
}
.section-title{font-family:'Syne',sans-serif;font-size:clamp(1.6rem,4vw,2.6rem);font-weight:800;line-height:1.2;margin-bottom:.75rem}
.section-sub{color:var(--text2);max-width:520px;margin-bottom:3rem}

/* ============================================================
   FILTERS & SUBJECTS GRID
============================================================ */
#sujets{background:var(--bg2)}
.filters{display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:2.5rem}
.filter-btn{
  padding:.45rem 1.1rem;border-radius:50px;font-size:.85rem;font-weight:500;cursor:pointer;
  border:1px solid var(--border);background:var(--card);color:var(--text2);transition:all .2s;
}
.filter-btn.active,.filter-btn:hover{background:var(--teal);color:#000;border-color:var(--teal)}
.subjects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem}

/* Subject Card */
.subject-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  overflow:hidden;transition:transform .25s,box-shadow .25s;cursor:pointer;position:relative;
}
.subject-card:hover{transform:translateY(-5px);box-shadow:0 20px 50px rgba(0,0,0,.4)}
.card-top{
  height:140px;display:flex;align-items:center;justify-content:center;position:relative;
  overflow:hidden;
}
.card-top.maths{background:linear-gradient(135deg,#1a1f3a,#0f3460)}
.card-top.pc{background:linear-gradient(135deg,#1a2f1a,#0d3320)}
.card-top.svt{background:linear-gradient(135deg,#2a1a2a,#3d0f3d)}
.card-icon{font-size:3rem;opacity:.8;z-index:1}
.card-top::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:40px;
  background:linear-gradient(to bottom,transparent,var(--card));
}
.card-badge{
  position:absolute;top:.75rem;right:.75rem;
  padding:.25rem .7rem;border-radius:50px;font-size:.72rem;font-weight:700;z-index:2;
}
.badge-free{background:rgba(0,212,170,.15);border:1px solid var(--teal);color:var(--teal)}
.badge-premium{background:rgba(245,200,66,.15);border:1px solid var(--gold);color:var(--gold)}
.card-body{padding:1.25rem}
.card-matiere{font-size:.72rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin-bottom:.4rem}
.card-title{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;margin-bottom:.5rem;line-height:1.3}
.card-meta{display:flex;align-items:center;gap:1rem;font-size:.78rem;color:var(--text3);margin-bottom:1.1rem}
.card-meta span{display:flex;align-items:center;gap:.3rem}
.card-footer{display:flex;align-items:center;justify-content:space-between}
.btn-view{
  display:flex;align-items:center;gap:.4rem;padding:.45rem 1.1rem;border-radius:8px;
  font-size:.83rem;font-weight:600;cursor:pointer;border:none;transition:all .2s;
}
.btn-view.free{background:rgba(0,212,170,.12);color:var(--teal);border:1px solid rgba(0,212,170,.25)}
.btn-view.free:hover{background:var(--teal);color:#000}
.btn-view.locked{background:rgba(245,200,66,.1);color:var(--gold);border:1px solid rgba(245,200,66,.25)}
.btn-view.locked:hover{background:var(--gold);color:#000}
.card-lock{font-size:1.1rem;color:var(--gold);opacity:.7}

/* Progress bar */
.free-progress{margin:0 0 2rem;padding:1rem 1.5rem;background:var(--card);border:1px solid var(--border);border-radius:12px;display:flex;align-items:center;gap:1.5rem}
.progress-text{font-size:.85rem;color:var(--text2);white-space:nowrap}
.progress-bar{flex:1;height:6px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--teal),var(--gold));border-radius:3px;transition:width .5s ease}
.progress-cta{font-size:.8rem;color:var(--gold);white-space:nowrap;cursor:pointer}
.progress-cta:hover{text-decoration:underline}

/* ============================================================
   HOW IT WORKS
============================================================ */
#comment{background:var(--bg3)}
.steps-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.5rem;counter-reset:step}
.step-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:2rem 1.5rem;position:relative;text-align:center;transition:border-color .2s;
}
.step-card:hover{border-color:var(--teal)}
.step-num{
  width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--teal2));
  color:#000;font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;
  display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;
}
.step-icon{font-size:1.6rem;margin-bottom:1rem;color:var(--gold)}
.step-title{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;margin-bottom:.5rem}
.step-desc{font-size:.85rem;color:var(--text2);line-height:1.6}

/* ============================================================
   QUIZ SECTION
============================================================ */
#quiz{background:var(--bg2)}
.quiz-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:2.5rem;max-width:680px;margin:0 auto;
}
.quiz-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem}
.quiz-timer{
  display:flex;align-items:center;gap:.5rem;color:var(--red);font-family:'Syne',sans-serif;font-weight:700;font-size:1.2rem;
}
.quiz-score-display{font-size:.85rem;color:var(--text2)}
.quiz-progress{height:4px;background:rgba(255,255,255,.06);border-radius:2px;margin-bottom:1.5rem;overflow:hidden}
.quiz-progress-fill{height:100%;background:linear-gradient(90deg,var(--teal),var(--blue));border-radius:2px;transition:width .3s}
.quiz-question{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:600;margin-bottom:1.5rem;line-height:1.5}
.quiz-options{display:grid;gap:.75rem;margin-bottom:1.5rem}
.quiz-option{
  padding:.85rem 1.2rem;border-radius:10px;border:1px solid var(--border);background:var(--bg3);
  cursor:pointer;font-size:.9rem;text-align:left;transition:all .2s;color:var(--text);
}
.quiz-option:hover{border-color:var(--teal);background:rgba(0,212,170,.06)}
.quiz-option.correct{border-color:var(--teal);background:rgba(0,212,170,.12);color:var(--teal)}
.quiz-option.wrong{border-color:var(--red);background:rgba(255,71,87,.1);color:var(--red)}
.quiz-controls{display:flex;gap:1rem}
.btn-quiz{
  flex:1;padding:.75rem;border-radius:10px;font-weight:600;font-size:.9rem;cursor:pointer;border:none;
  transition:all .2s;
}
.btn-quiz.primary{background:linear-gradient(135deg,var(--teal),var(--teal2));color:#000}
.btn-quiz.secondary{background:var(--bg3);color:var(--text2);border:1px solid var(--border)}
.quiz-result{text-align:center;padding:2rem 0}
.result-score{font-family:'Syne',sans-serif;font-size:4rem;font-weight:800;color:var(--gold)}
.result-label{color:var(--text2);margin-bottom:1.5rem}

/* ============================================================
   CONSEILS SECTION
============================================================ */
#conseils{background:var(--bg3)}
.conseils-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem}
.conseil-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:1.75rem;transition:all .25s;
}
.conseil-card:hover{transform:translateY(-4px);border-color:rgba(245,200,66,.3)}
.conseil-icon{font-size:2rem;margin-bottom:1rem}
.conseil-title{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;margin-bottom:.5rem}
.conseil-text{font-size:.85rem;color:var(--text2);line-height:1.65}

/* ============================================================
   CLASSEMENT
============================================================ */
#classement{background:var(--bg2)}
.leaderboard{max-width:560px;margin:0 auto}
.lb-item{
  display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem;
  border-radius:12px;margin-bottom:.75rem;background:var(--card);border:1px solid var(--border);
  transition:border-color .2s;
}
.lb-item:first-child{border-color:var(--gold);background:rgba(245,200,66,.05)}
.lb-item:nth-child(2){border-color:rgba(192,192,192,.3)}
.lb-item:nth-child(3){border-color:rgba(205,127,50,.3)}
.lb-rank{font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;width:2rem;text-align:center}
.lb-rank.gold{color:var(--gold)}
.lb-rank.silver{color:#c0c0c0}
.lb-rank.bronze{color:#cd7f32}
.lb-avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--blue));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;color:#000}
.lb-name{flex:1;font-weight:600;font-size:.9rem}
.lb-score{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;color:var(--teal)}
.lb-badge{font-size:.7rem;background:rgba(0,212,170,.1);color:var(--teal);padding:.2rem .6rem;border-radius:50px;border:1px solid rgba(0,212,170,.2)}

/* ============================================================
   TÉMOIGNAGES
============================================================ */
#temoignages{background:var(--bg3)}
.temoignages-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem}
.temoignage-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:1.75rem;transition:all .25s;
}
.temoignage-card:hover{border-color:rgba(0,212,170,.25)}
.stars{color:var(--gold);font-size:.9rem;margin-bottom:.75rem}
.temoignage-text{font-size:.88rem;color:var(--text2);line-height:1.65;font-style:italic;margin-bottom:1.25rem}
.temoignage-author{display:flex;align-items:center;gap:.75rem}
.author-avatar{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--red));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;color:#fff}
.author-name{font-weight:600;font-size:.85rem}
.author-info{font-size:.75rem;color:var(--text3)}

/* ============================================================
   CTA SECTION
============================================================ */
#acces{background:var(--bg)}
.cta-box{
  background:linear-gradient(135deg,rgba(0,212,170,.1),rgba(245,200,66,.06));
  border:1px solid rgba(0,212,170,.2);border-radius:24px;padding:4rem 2.5rem;
  text-align:center;max-width:700px;margin:0 auto;
}
.cta-box h2{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;margin-bottom:1rem}
.cta-box p{color:var(--text2);margin-bottom:2.5rem}
.cta-payment-methods{display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;margin-bottom:2rem}
.payment-badge{
  background:var(--card);border:1px solid var(--border);padding:.5rem 1.25rem;border-radius:8px;
  font-size:.85rem;font-weight:600;display:flex;align-items:center;gap:.5rem;color:var(--text2);
}
.payment-badge .dot{width:8px;height:8px;border-radius:50%}
.payment-badge .dot.orange{background:#ff6b00}
.payment-badge .dot.blue{background:#0099cc}

/* ============================================================
   CODE MODAL
============================================================ */
.modal-overlay{
  display:none;position:fixed;inset:0;z-index:9000;
  background:rgba(0,0,0,.75);backdrop-filter:blur(10px);
  align-items:center;justify-content:center;padding:1.5rem;
}
.modal-overlay.show{display:flex}
.modal{
  background:var(--card);border:1px solid var(--border);border-radius:20px;
  padding:2.5rem;max-width:420px;width:100%;position:relative;
  animation:modalIn .3s ease;
}
@keyframes modalIn{from{opacity:0;transform:scale(.93) translateY(10px)}to{opacity:1;transform:scale(1) translateY(0)}}
.modal-close{position:absolute;top:1rem;right:1rem;background:var(--bg3);border:1px solid var(--border);color:var(--text2);width:32px;height:32px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.9rem;transition:all .2s}
.modal-close:hover{color:var(--red);border-color:var(--red)}
.modal-icon{font-size:2.5rem;margin-bottom:1rem;text-align:center}
.modal h3{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:700;margin-bottom:.5rem;text-align:center}
.modal p{color:var(--text2);font-size:.88rem;text-align:center;margin-bottom:1.5rem;line-height:1.6}
.modal-input{
  width:100%;padding:.85rem 1rem;border-radius:10px;border:1.5px solid var(--border);
  background:var(--bg3);color:var(--text);font-size:1rem;text-align:center;letter-spacing:.15em;
  font-family:'Syne',sans-serif;font-weight:600;text-transform:uppercase;transition:border-color .2s;margin-bottom:.75rem;
}
.modal-input:focus{outline:none;border-color:var(--teal)}
.modal-input::placeholder{letter-spacing:.05em;text-transform:none;font-family:'DM Sans',sans-serif;font-weight:400;opacity:.5}
.btn-modal{width:100%;padding:.85rem;border-radius:10px;font-weight:700;font-size:.95rem;cursor:pointer;border:none;transition:all .2s;margin-bottom:.5rem}
.btn-modal.verify{background:linear-gradient(135deg,var(--teal),var(--teal2));color:#000}
.btn-modal.verify:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(0,212,170,.3)}
.btn-modal.whatsapp{background:#25d366;color:#fff}
.btn-modal.whatsapp:hover{background:#1ebe5d}
.modal-msg{font-size:.82rem;text-align:center;padding:.5rem;border-radius:8px;display:none}
.modal-msg.success{background:rgba(0,212,170,.1);color:var(--teal);border:1px solid rgba(0,212,170,.2)}
.modal-msg.error{background:rgba(255,71,87,.1);color:var(--red);border:1px solid rgba(255,71,87,.2)}
.modal-msg.show{display:block}

/* ============================================================
   ADMIN PANEL
============================================================ */
.admin-overlay{
  display:none;position:fixed;inset:0;z-index:9100;
  background:rgba(0,0,0,.9);backdrop-filter:blur(15px);
