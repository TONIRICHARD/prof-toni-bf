async function openPDF(id){
  const s = [...SUBJECTS, ...dynamicSujets].find(x=>x.id===id);
  if(!s) return;

  // Track vues gratuites
  if(s.free){
    let v = parseInt(localStorage.getItem('pcp_viewed') || 0);
    localStorage.setItem('pcp_viewed', v+1);
    updateProgressBar();
  }

  if(!s.pdf || s.pdf === '#'){
    // Sujet démo sans vrai PDF
    showMsg('📄 Ce sujet sera bientôt disponible. Revenez plus tard !');
    return;
  }

  // Récupérer le vrai lien depuis Firebase (caché côté serveur)
  let pdfUrl = s.pdf;
  if(fbReady && db){
    try{
      const snap = await db.ref('sujets/'+s.id+'/pdf').once('value');
      if(snap.val()) pdfUrl = snap.val();
    } catch(e){}
  }

  // Convertir Google Drive → /preview (meilleur défilement sur mobile)
  let downloadUrl = pdfUrl; // Garder le lien original pour le téléchargement
  if(pdfUrl.includes('drive.google.com')){
    pdfUrl = pdfUrl
      .replace('/view','')
      .replace('/edit','')
      .replace('/preview','');
    const match = pdfUrl.match(/\/d\/([a-zA-Z0-9_-]+)/);
    if(match){
      const fileId = match[1];
      pdfUrl = 'https://drive.google.com/file/d/' + fileId + '/preview?rm=minimal';
      // Lien de téléchargement direct Google Drive
      downloadUrl = 'https://drive.google.com/uc?export=download&id=' + fileId;
    }
  }

  // Bouton téléchargement : visible uniquement si l'élève a payé (hasAccess)
  // Les sujets gratuits = lecture seule, les payants = lecture + téléchargement
  const btnDl = document.getElementById('btn-telecharger');
  if(hasAccess && !s.free){
    btnDl.href = downloadUrl;
    btnDl.style.display = 'flex';
  } else {
    btnDl.style.display = 'none';
  }

  // Afficher dans le viewer sécurisé intégré
  document.getElementById('pdf-title').textContent = '📄 ' + s.titre;
  document.getElementById('pdf-frame').src = pdfUrl;
  document.getElementById('pdf-overlay').classList.add('show');

  // Bloquer clic droit sur toute la page quand le viewer est ouvert
  document.addEventListener('contextmenu', blockContext);
}

function blockContext(e){ e.preventDefault(); return false; }

function closePDF(){
  document.getElementById('pdf-overlay').classList.remove('show');
  document.getElementById('pdf-frame').src = '';
  document.removeEventListener('contextmenu', blockContext);
}

